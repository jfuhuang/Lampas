# Copy to .env (or set in your host's dashboard, e.g. Vercel project settings).
#
# VITE_SERVER_URL — where the Socket.IO server lives.
#   Leave UNSET for the monolith deploy (Node serves client + websocket on one URL)
#   and for local dev (Vite proxies /socket.io to :3000).
#   Set it ONLY for a split deploy: client on Vercel, server elsewhere.
#   Must be https:// — phones need a secure context for GPS/camera.
#
# VITE_SERVER_URL=https://lampas-server.onrender.com
